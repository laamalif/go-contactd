# Docker/compose host port mapping (host:container 8080)
CONTACTD_HOST_PORT=8080
# Compose/container path (set explicitly because service default is /var/db/contactd.db)
CONTACTD_DB_PATH=/data/contactd.sqlite

# Optional absolute base URL for redirects (DAV hrefs remain root-relative)
# CONTACTD_BASE_URL=https://contacts.example.com

# Logging
CONTACTD_LOG_LEVEL=info
CONTACTD_LOG_FORMAT=text

# Reverse proxy trust (keep false unless running behind a trusted proxy boundary)
CONTACTD_TRUST_PROXY_HEADERS=false

# Request/body limits
CONTACTD_REQUEST_MAX_BYTES=10485760
CONTACTD_VCARD_MAX_BYTES=10485760

# Change journal retention / pruning
CONTACTD_CHANGE_RETENTION_DAYS=180
CONTACTD_CHANGE_RETENTION_MAX_REVISIONS=0
CONTACTD_PRUNE_INTERVAL=24h

# Optional Task 7 extension (default off)
CONTACTD_ENABLE_ADDRESSBOOK_COLOR=false

# Bootstrap-only user seed (applied only to empty DB unless --force-seed)
# Format: username:bcryptHash[,username:bcryptHash...]
# CONTACTD_USERS=

# Optional default addressbook seed values
# CONTACTD_DEFAULT_BOOK_SLUG=contacts
# CONTACTD_DEFAULT_BOOK_NAME=Contacts
